# ================================================
# ENVIRONMENT VARIABLES REQUIRED FOR G97 PROJECT
# ================================================

# MongoDB Connection String (Get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/g97?retryWrites=true&w=majority

# JWT Secret Key (Generate a strong random string - min 32 chars)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# ================================================
# EMAIL CONFIGURATION (REQUIRED FOR OTP TO WORK)
# ================================================

# Gmail Address (your actual Gmail)
MAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password!)
# 1. Enable 2-Factor Authentication on Gmail
# 2. Go to Google Account > Security > App Passwords
# 3. Create new app password for "Mail"
# 4. Use that 16-character password here
MAIL_PASS=your-16-char-app-password

# ================================================
# OPTIONAL CONFIGURATIONS
# ================================================

# Server Port (default: 5000)
PORT=5000

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Environment (production/development)
NODE_ENV=development

